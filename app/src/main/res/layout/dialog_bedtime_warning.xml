<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_time"
        android:tint="#5856D6" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:fontFamily="sans-serif-medium"
        android:text="Bedtime Mode"
        android:textColor="#1C1C1E"
        android:textSize="20sp" />

    <TextView
        android:id="@+id/tvBedtimeMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:text="It's past your bedtime. Take a break and get some rest."
        android:textColor="#8E8E93"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnBedtimeOverride"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_button_primary"
        android:text="Override for Tonight"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnBedtimeClose"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@android:color/transparent"
        android:text="Close App"
        android:textAllCaps="false"
        android:textColor="#8E8E93"
        android:textSize="14sp" />

</LinearLayout>
